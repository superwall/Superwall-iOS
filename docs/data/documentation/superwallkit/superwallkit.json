{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"Superwall makes it easy to show paywalls in your app using UIKit or SwiftUI. If you haven’t already, "},{"isActive":true,"type":"reference","identifier":"https:\/\/superwall.com\/sign-up"},{"text":". Configure the SDK with your API key and present our example paywall in response to a registered placement. When you’re ready to use your own paywalls, head to the Superwall dashboard and use the paywall editor to configure them. Then, create a Campaign and define audiences to determine when to show paywalls to users.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See our "},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.superwall.com\/docs"},{"type":"text","text":" for more information."}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit"]]},"abstract":[{"type":"text","text":"The client SDK for "},{"isActive":true,"type":"reference","identifier":"https:\/\/superwall.com"},{"type":"text","text":", a service that lets you remotely configure, present and iterate paywalls – helping you find winners quickly."}],"kind":"article","variants":[{"paths":["\/documentation\/superwallkit\/superwallkit"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"`SuperwallKit`","role":"collectionGroup","modules":[{"name":"SuperwallKit"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/SuperwallKit","interfaceLanguage":"swift"},"references":{"https://superwall.com/sign-up":{"identifier":"https:\/\/superwall.com\/sign-up","title":"sign up for a free Superwall account","type":"link","titleInlineContent":[{"text":"sign up for a free Superwall account","type":"text"}],"url":"https:\/\/superwall.com\/sign-up"},"doc: