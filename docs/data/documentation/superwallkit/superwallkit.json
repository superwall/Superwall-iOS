{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Superwall makes it easy to show paywalls in your app using UIKit or SwiftUI. If you haven’t already, "},{"type":"reference","identifier":"https:\/\/superwall.com\/sign-up","isActive":true},{"type":"text","text":". Configure the SDK with your API key and present our example paywall in response to a registered placement. When you’re ready to use your own paywalls, head to the Superwall dashboard and use the paywall editor to configure them. Then, create a Campaign and define audiences to determine when to show paywalls to users."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See our "},{"type":"reference","identifier":"https:\/\/docs.superwall.com\/docs","isActive":true},{"type":"text","text":" for more information."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/superwallkit\/superwallkit"]}],"kind":"article","metadata":{"modules":[{"name":"SuperwallKit"}],"role":"collectionGroup","title":"`SuperwallKit`"},"sections":[],"abstract":[{"text":"The client SDK for ","type":"text"},{"identifier":"https:\/\/superwall.com","isActive":true,"type":"reference"},{"text":", a service that lets you remotely configure, present and iterate paywalls – helping you find winners quickly.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/SuperwallKit"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"https://superwall.com/sign-up":{"url":"https:\/\/superwall.com\/sign-up","title":"sign up for a free Superwall account","titleInlineContent":[{"text":"sign up for a free Superwall account","type":"text"}],"identifier":"https:\/\/superwall.com\/sign-up","type":"link"},"doc: