{"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Superwall makes it easy to show paywalls in your app using UIKit or SwiftUI. If you haven’t already, "},{"isActive":true,"type":"reference","identifier":"https:\/\/superwall.com\/sign-up"},{"type":"text","text":". Configure the SDK with your API key and present our example paywall in response to a registered placement. When you’re ready to use your own paywalls, head to the Superwall dashboard and use the paywall editor to configure them. Then, create a Campaign and define audiences to determine when to show paywalls to users."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See our "},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.superwall.com\/docs"},{"type":"text","text":" for more information."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"The client SDK for "},{"isActive":true,"identifier":"https:\/\/superwall.com","type":"reference"},{"type":"text","text":", a service that lets you remotely configure, present and iterate paywalls – helping you find winners quickly."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/superwallkit\/superwallkit"]}],"hierarchy":{"paths":[["doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/SuperwallKit"},"kind":"article","metadata":{"title":"`SuperwallKit`","modules":[{"name":"SuperwallKit"}],"role":"collectionGroup"},"references":{"https://superwall.com/sign-up":{"url":"https:\/\/superwall.com\/sign-up","type":"link","titleInlineContent":[{"type":"text","text":"sign up for a free Superwall account"}],"title":"sign up for a free Superwall account","identifier":"https:\/\/superwall.com\/sign-up"},"http