ype":"codeVoice"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}]}]},{"name":"paywallOverrides","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional completion block that gets called when the paywall should dismiss. This defaults to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"type":"codeVoice","code":"presentationMode.wrappedValue.dismiss()"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}],"name":"onRequestDismiss"},{"content":[{"inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","type":"reference","isActive":true},{"text":" and returns an ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"onSkippedView"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/superwall.com\/dashboard","isActive":true},{"type":"text","text":". If the paywall is set to "},{"inlineContent":[{"type":"text","text":"Non Gated"}],"type":"emphasis"},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Gated"}]},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}],"name":"feature"}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses "},{"type":"codeVoice","code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)"},{"type":"text","text":" under the hood."}]},{"type":"aside","style":"warning","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re responsible for the deallocation of this view. If you have a "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" presented somewhere"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" elsewhere, you will get a crash."}]}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView\/init(placement:params:paywallOverrides:onRequestDismiss:onSkippedView:feature:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\