o ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}],"type":"paragraph"}]},{"name":"onSkippedView","content":[{"inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","isActive":true,"type":"reference"},{"text":" and returns an ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"name":"feature","content":[{"inlineContent":[{"text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/superwall.com\/dashboard","isActive":true,"type":"reference"},{"text":". If the paywall is set to ","type":"text"},{"inlineContent":[{"text":"Non Gated","type":"text"}],"type":"emphasis"},{"text":", this will be called when","type":"text"},{"text":" ","type":"text"},{"text":"the paywall is dismissed or if the user is already paying. If the paywall is ","type":"text"},{"inlineContent":[{"text":"Gated","type":"text"}],"type":"emphasis"},{"text":", this will be called only if the user is already paying","type":"text"},{"text":" ","type":"text"},{"text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent"