{"abstract":[{"text":"A SwiftUI paywall view that you can embed into your app.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"text":"placement","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"params","kind":"externalParam"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"]? = nil, ","kind":"text"},{"text":"paywallOverrides","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","preciseIdentifier":"c:@M@SuperwallKit@objc(cs)SWKPaywallOverrides","text":"PaywallOverrides","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"onRequestDismiss","kind":"externalParam"},{"text":": ((","kind":"text"},{"text":"PaywallInfo","kind":"typeIdentifier","preciseIdentifier":"c:@M@SuperwallKit@objc(cs)SWKPaywallInfo","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallInfo"},{"text":", ","kind":"text"},{"text":"PaywallResult","kind":"typeIdentifier","preciseIdentifier":"s:12SuperwallKit13PaywallResultO","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallResult"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")? = nil, ","kind":"text"},{"text":"feature","kind":"externalParam"},{"text":": (() -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")? = nil)","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"placement","content":[{"inlineContent":[{"type":"text","text":"The name of the placement, as you have defined on the Superwall dashboard."}],"type":"paragraph"}]},{"name":"params","content":[{"inlineContent":[{"type":"text","text":"Optional parameters you’d like to pass with your event. These can be referenced within the rules"},{"type":"text","text":" "},{"type":"text","text":"of your campaign. Keys beginning with "},{"code":"$","type":"codeVoice"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}],"type":"paragraph"}]},{"name":"paywallOverrides","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","type":"reference","isActive":true},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional completion block that gets called when the paywall should dismiss. This defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}],"name":"onRequestDismiss"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/superwall.com\/dashboard","isActive":true},{"type":"text","text":". If the paywall is set to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Non Gated"}]},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Gated"}]},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}],"name":"feature"}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses "},{"type":"codeVoice","code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)"},{"type":"text","text":" under the hood."}]},{"name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re responsible for the deallocation of this view. If you have a "},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":" presented somewhere"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" elsewhere, you will get a crash."}]}],"type":"aside"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit","doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/superwallkit\/paywallview\/init(placement:params:paywalloverrides:onr