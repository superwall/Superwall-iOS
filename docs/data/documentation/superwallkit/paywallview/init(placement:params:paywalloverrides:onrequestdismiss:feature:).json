{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"A SwiftUI paywall view that you can embed into your app.","type":"text"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"text":"placement","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"params","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"]? = nil, ","kind":"text"},{"text":"paywallOverrides","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"PaywallOverrides","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","kind":"typeIdentifier","preciseIdentifier":"c:@M@SuperwallKit@objc(cs)SWKPaywallOverrides"},{"text":"? = nil, ","kind":"text"},{"text":"onRequestDismiss","kind":"externalParam"},{"text":": ((","kind":"text"},{"text":"PaywallInfo","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallInfo","kind":"typeIdentifier","preciseIdentifier":"c:@M@SuperwallKit@objc(cs)SWKPaywallInfo"},{"text":", ","kind":"text"},{"text":"PaywallResult","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallResult","kind":"typeIdentifier","preciseIdentifier":"s:12SuperwallKit13PaywallResultO"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")? = nil, ","kind":"text"},{"text":"feature","kind":"externalParam"},{"text":": (() -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":")? = nil)","kind":"text"}],"languages":["swift"],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The name of the placement, as you have defined on the Superwall dashboard."}]}],"name":"placement"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional parameters you’d like to pass with your event. These can be referenced within the rules"},{"type":"text","text":" "},{"type":"text","text":"of your campaign. Keys beginning with "},{"type":"codeVoice","code":"$"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}]}],"name":"params"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"name":"paywallOverrides"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional completion block that gets called when the paywall should dismiss. This defaults to "},{"type":"codeVoice","code":"nil"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"type":"codeVoice","code":"presentationMode.wrappedValue.dismiss()"},{"type":"text","text":" by default. Otherwise you must perform the dismissal of the paywall."}]}],"name":"onRequestDismiss"},{"name":"feature","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/superwall.com\/dashboard"},{"type":"text","text":". If the paywall is set to "},{"inlineContent":[{"text":"Non Gated","type":"text"}],"type":"emphasis"},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"inlineContent":[{"type":"text","text":"Gated"}],"type":"emphasis"},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses "},{"code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)","type":"codeVoice"},{"type":"text","text":" under the hood."}]},{"content":[{"inlineContent":[{"type":"text","text":"You’re responsible for the deallocation of this view. If you have a "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" presented somewhere"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" elsewhere, you will get a crash."}],"type":"paragraph"}],"type":"aside","name":"Warning","style":"warning"}]}],"metadata":{"symbolKind":"init","conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"OnErrorView"},{"type":"text","text":" is "},{"type":"codeVoice","code":"Never"},{"type":"text","text":" and "},{"type":"codeVoi