},{"kind":"text","text":": (() -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":")? = nil)"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"placement","content":[{"inlineContent":[{"text":"The name of the placement, as you have defined on the Superwall dashboard.","type":"text"}],"type":"paragraph"}]},{"name":"params","content":[{"type":"paragraph","inlineContent":[{"text":"Optional parameters you’d like to pass with your event. These can be referenced within the rules","type":"text"},{"text":" ","type":"text"},{"text":"of your campaign. Keys beginning with ","type":"text"},{"code":"$","type":"codeVoice"},{"text":" are reserved for Superwall and will be dropped. Values can be any","type":"text"},{"text":" ","type":"text"},{"text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will","type":"text"},{"text":" ","type":"text"},{"text":"be dropped.","type":"text"}]}]},{"name":"paywallOverrides","content":[{"inlineContent":[{"type":"text","text":"An optional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"onRequestDismiss","content":[{"type":"paragraph","inlineContent":[{"text":"An optional completion block that gets called when the paywall should dismiss. This defaults to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}]},{"name":"feature","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/superwall.com\/dashboard"},{"type":"text","text":". If the paywall is set to "},{"type":"emphasis","inlineContent":[{"text":"Non Gated","type":"text"}]},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"type":"emphasis","inlineContent":[{"text":"Gated","type":"text"}]},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This uses ","type":"text"},{"code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)","type":"codeVoice"},{"text":" under the hood.","type":"text"}]},{"style":"warning","type":"aside","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"text":"You’re responsible for the deallocation of this view. If you have a ","type":"text"},{"type":"codeVoice","code":"PaywallView"},{"text":" presented somewhere","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"text":" elsewhere, you will get a crash.","type":"text"}]}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/superwallkit\/paywallview\/init(placement:params:paywalloverrides:onrequestdismiss:feature:)"],"traits":[{"interfaceLanguag