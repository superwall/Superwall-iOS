text","text":"The name of the placement, as you have defined on the Superwall dashboard."}]}]},{"name":"params","content":[{"inlineContent":[{"type":"text","text":"Optional parameters you’d like to pass with your event. These can be referenced within the rules"},{"type":"text","text":" "},{"type":"text","text":"of your campaign. Keys beginning with "},{"type":"codeVoice","code":"$"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}],"type":"paragraph"}]},{"name":"paywallOverrides","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","type":"reference","isActive":true},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"name":"onRequestDismiss","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional completion block that gets called when the paywall should dismiss. This defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and the SDK"},{"type":"text","text":" "},{"type":"text","text":"will call "},{"type":"codeVoice","code":"presentationMode.wrappedValue.dismiss()"},{"type":"text","text":" by default. Otherwise you must perform the dismissal of the paywall."}]}]},{"name":"feature","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"identifier":"https:\/\/superwall.com\/dashboard","type":"reference","isActive":true},{"type":"text","text":". If the paywall is set to "},{"inlineContent":[{"type":"text","text":"Non Gated"}],"type":"emphasis"},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"inlineContent":[{"type":"text","text":"Gated"}],"type":"emphasis"},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses "},{"type":"codeVoice","code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)"},{"type":"text","text":" under the hood."}]},{"style":"warning","type":"aside","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re responsible for the deallocation of this view. If you have a "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" presented somewhere"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" elsewhere, you will get a crash."}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView\/init(placement:params:paywallOverrides:onRequestDismiss:feature:)"},"hierarchy":{"paths":[["doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit","doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView"]]},"metadata":{"externalID":"s:12SuperwallKit11PaywallViewVAAs5NeverORszAERs_rlE9pla