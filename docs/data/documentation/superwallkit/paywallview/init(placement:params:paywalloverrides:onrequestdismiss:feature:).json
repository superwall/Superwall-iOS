perwallKit@objc(cs)SWKPaywallInfo","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallInfo","text":"PaywallInfo"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:12SuperwallKit13PaywallResultO","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallResult","text":"PaywallResult"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")? = nil, "},{"kind":"externalParam","text":"feature"},{"kind":"text","text":": (() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")? = nil)"}]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The name of the placement, as you have defined on the Superwall dashboard."}]}],"name":"placement"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional parameters you’d like to pass with your event. These can be referenced within the rules"},{"type":"text","text":" "},{"type":"text","text":"of your campaign. Keys beginning with "},{"type":"codeVoice","code":"$"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}]}],"name":"params"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","isActive":true},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"name":"paywallOverrides"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional completion block that gets called when the paywall should dismiss. This defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and the SDK"},{"type":"text","text":" "},{"type":"text","text":"will call "},{"type":"codeVoice","code":"presentationMode.wrappedValue.dismiss()"},{"type":"text","text":" by default. Otherwise you must perform the dismissal of the paywall."}]}],"name":"onRequestDismiss"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/superwall.com\/dashboard","isActive":true},{"type":"text","text":". If the paywall is set to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Non Gated"}]},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Gated"}]},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}],"name":"feature"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This uses "},{"type":"reference","isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)"},{"type":"text","text":" under the hood."}],"type":"paragraph"},{"style":"warning","content":[{"typ