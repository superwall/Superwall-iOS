","type":"text"},{"text":" ","type":"text"},{"text":"to override products and whether it ignores the subscription status. Defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"paywallOverrides"},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional completion block that gets called when the paywall should dismiss. This defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}],"name":"onRequestDismiss"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","isActive":true},{"text":" and returns an ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"onSkippedView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts an ","type":"text"},{"code":"Error","type":"codeVoice"},{"text":" and returns a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show when the requested","type":"text"},{"text":" ","type":"text"},{"text":"paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"onErrorView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/superwall.com\/dashboard","isActive":true},{"text":". If the paywall is set to ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Non Gated","type":"text"}]},{"text":", this will be called when","type":"text"},{"text":" ","type":"text"},{"text":"the paywall is dismissed or if the user is already paying. If the paywall is ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Gated","type":"text"}]},{"text":", this will be called only if the user is already paying","type":"text"},{"text":" ","type":"text"},{"text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error.","type":"text"}]}],"name":"feature"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This uses "},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)","type":"reference","isActive":true},{"type":"text","text":" under the hood."}],"type":"paragraph"},{"style":"warning","content":[{"type":"paragraph","inlineContent":[{"text":"You’re responsible for the deallocation of this view. If you have a ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" presented somewhere","type":"text"},{"text":" ","type":"text"},{"text":"and you try to present the same ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" elsewhere, you will get a crash.","type":"text"}]}],"name":"Warning","type":"aside"}],"kind":"content"}],"metadata":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"placement"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"params"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","te