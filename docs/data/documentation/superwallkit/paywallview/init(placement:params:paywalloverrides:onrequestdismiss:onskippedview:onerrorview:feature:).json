eters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The name of the placement, as you have defined on the Superwall dashboard.","type":"text"}]}],"name":"placement"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional parameters you’d like to pass with your placement. These can be referenced within the rules"},{"type":"text","text":" "},{"type":"text","text":"of your campaign. Keys beginning with "},{"type":"codeVoice","code":"$"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}]}],"name":"params"},{"content":[{"inlineContent":[{"type":"text","text":"An optional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"text":" ","type":"text"},{"text":"to override products and whether it ignores the subscription status. Defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"paywallOverrides"},{"content":[{"inlineContent":[{"type":"text","text":"An optional completion block that gets called when the paywall should dismiss. This defaults to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and the SDK"},{"type":"text","text":" "},{"type":"text","text":"will call "},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"type":"text","text":" by default. Otherwise you must perform the dismissal of the paywall."}],"type":"paragraph"}],"name":"onRequestDismiss"},{"content":[{"inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","isActive":true},{"text":" and returns an ","type":"text"},{"type":"codeVoice","code":"View"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"type":"codeVoice","code":"EmptyView()"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"onSkippedView"},{"content":[{"inlineContent":[{"type":"text","text":"A completion block that accepts an "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" and returns a "},{"type":"codeVoice","code":"View"},{"type":"text","text":". This will show when the requested"},{"type":"text","text":" "},{"type":"text","text":"paywall is skipped. Defaults to "},{"type":"codeVoice","code":"EmptyView()"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"onErrorView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/superwall.com\/dashboard"},{"text":". If the paywall is set to ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Non Gated"}]},{"text":", this will be called when","type":"text"},{"text":" ","type":"text"},{"text":"the paywall is dismissed or if the user is already paying. If the paywall is ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Gated","type":"text"}]},{"text":", this will be called only if the user is already paying","type":"text"},{"text":" ","type":"text"},{"text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error.","type":"text"}]}],"name":"feature"}],"kind":"parameters"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{