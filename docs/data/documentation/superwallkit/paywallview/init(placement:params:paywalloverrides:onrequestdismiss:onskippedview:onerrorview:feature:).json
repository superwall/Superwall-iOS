 ","type":"text"},{"code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)","type":"codeVoice"},{"text":" under the hood.","type":"text"}]},{"name":"Warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re responsible for the deallocation of this view. If you have a "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" presented somewhere"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" elsewhere, you will get a crash."}]}],"style":"warning"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView\/init(placement:params:paywallOverrides:onRequestDismiss:onSkippedView:onErrorView:feature:)"},"sections":[],"references":{"https://superwall.com/dashboard":{"type":"link","url":"https:\/\/superwall.com\/dashboard","identifier":"https:\/\/superwall.com\/dashboard","title":"Superwall Dashboard","titleInlineContent":[{"type":"text","text":"Superwall Dashboard"}]},"doc://superwall-ios.SuperwallKit/documentation/SuperwallKit/PaywallInfo":{"title":"PaywallInfo","navigatorTitle":[{"kind":"identifier","text":"PaywallInfo"}],"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallInfo","abstract":[{"text":"Contains information about a paywall.","type":"text"}],"kind":"symbol","url":"\/documentation\/superwallkit\/paywallinfo","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallInfo"}],"type":"topic","role":"symbol"},"doc://superwall-ios.SuperwallKit/documentation/SuperwallKit/PaywallOverrides":{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","type":"topic","abstract":[{"text":"Override the default behavior and products of a payw