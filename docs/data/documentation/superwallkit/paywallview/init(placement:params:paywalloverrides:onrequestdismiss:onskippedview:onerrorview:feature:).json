,{"text":"to override products and whether it ignores the subscription status. Defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"paywallOverrides"},{"name":"onRequestDismiss","content":[{"inlineContent":[{"type":"text","text":"An optional completion block that gets called when the paywall should dismiss. This defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and the SDK"},{"type":"text","text":" "},{"type":"text","text":"will call "},{"type":"codeVoice","code":"presentationMode.wrappedValue.dismiss()"},{"type":"text","text":" by default. Otherwise you must perform the dismissal of the paywall."}],"type":"paragraph"}]},{"name":"onSkippedView","content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","isActive":true,"type":"reference"},{"text":" and returns an ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}]},{"name":"onErrorView","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block that accepts an "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" and returns a "},{"type":"codeVoice","code":"View"},{"type":"text","text":". This will show when the requested"},{"text":" ","type":"text"},{"text":"paywall is skipped. Defaults to ","type":"text"},{"type":"codeVoice","code":"EmptyView()"},{"type":"text","text":"."}]}]},{"name":"feature","content":[{"inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"type":"reference","identifier":"