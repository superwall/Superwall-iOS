ise you must perform the dismissal of the paywall.","type":"text"}]}],"name":"onRequestDismiss"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason"},{"text":" and returns an ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"onSkippedView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts an ","type":"text"},{"code":"Error","type":"codeVoice"},{"text":" and returns a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show when the requested","type":"text"},{"text":" ","type":"text"},{"text":"paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"onErrorView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/superwall.com\/dashboard"},{"text":". If the paywall is set to ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Non Gated","type":"text"}]},{"text":", this will be called when","type":"text"},{"text":" ","type":"text"},{"text":"the paywall is dismissed or if the user is already paying. If the paywall is ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Gated","type":"text"}]},{"text":", this will be called only if the user is already paying","type":"text"},{"text":" ","type":"text"},{"text":"or if they begin paying. If no paywall is configured, this gets called i