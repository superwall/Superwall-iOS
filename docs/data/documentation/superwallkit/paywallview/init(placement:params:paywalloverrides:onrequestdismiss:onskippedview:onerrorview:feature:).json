rameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The name of the placement, as you have defined on the Superwall dashboard."}]}],"name":"placement"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional parameters you’d like to pass with your placement. These can be referenced within the rules"},{"type":"text","text":" "},{"type":"text","text":"of your campaign. Keys beginning with "},{"type":"codeVoice","code":"$"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}]}],"name":"params"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"name":"paywallOverrides"},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional completion block that gets called when the paywall should dismiss. This defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}],"name":"onRequestDismiss"},{"content":[{"inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"isActive":true,"type":"reference","identifier":"do