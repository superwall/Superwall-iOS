},{"text":": ((","kind":"text"},{"preciseIdentifier":"c:@M@SuperwallKit@objc(cs)SWKPaywallInfo","text":"PaywallInfo","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallInfo","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:12SuperwallKit13PaywallResultO","text":"PaywallResult","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallResult","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":")? = nil, ","kind":"text"},{"text":"onSkippedView","kind":"externalParam"},{"text":": ((","kind":"text"},{"preciseIdentifier":"s:12SuperwallKit20PaywallSkippedReasonO","text":"PaywallSkippedReason","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"OnSkippedView","preciseIdentifier":"s:12SuperwallKit11PaywallViewV09OnSkippedD0q_mfp","kind":"typeIdentifier"},{"text":")? = nil, ","kind":"text"},{"text":"onErrorView","kind":"externalParam"},{"text":": ((","kind":"text"},{"text":"Error","preciseIdentifier":"s:s5ErrorP","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"OnErrorView","preciseIdentifier":"s:12SuperwallKit11PaywallViewV07OnErrorD0xmfp","kind":"typeIdentifier"},{"text":")? = nil, ","kind":"text"},{"text":"feature","kind":"externalParam"},{"text":": (() -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":")? = nil)","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The name of the placement, as you have defined on the Superwall dashboard."}],"type":"paragraph"}],"name":"placement"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Optional parameters you’d like to pass with your placement. These can be referenced within the rules","type":"text"},{"text":" ","type":"text"},{"text":"of your campaign. Keys beginning with ","type":"text"},{"code":"$","type":"codeVoice"},{"text":" are reserved for Superwall and will be dropped. Values can be any","type":"text"},{"text":" ","type":"text"},{"text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will","type":"text"},{"text":" ","type":"text"},{"text":"be dropped.","type":"text"}]}],"name":"params"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"isActive":true,"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}]}],"name":"paywallOverrides"},{"content":[{"inlineContent":[{"type":"text","text":"An optional completion block that gets called when the paywall should dismiss. This defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and the SDK"},{"type":"text","text":" "},{"type":"text","text":"will call "},{"type":"codeVoice","code":"presentationMode.wrappedValue.dismiss()"},{"type":"text","text":" by default. Otherwise you must perform the dismissal of the paywall."}],"type":"paragraph"}],"name":"onRequestDismiss"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","isActive":true},{"text":" and returns an ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"type":"codeVoice","code":"EmptyView()"},{"text":".","type":"text"}]}],"name":"onSkippedView"},{"content":[{"inlineContent":[{"type":"text","text":"A completion block that accepts an "},{"code":"Error","type":"codeVoice"},{"type":"text","text":" and returns a "},{"code":"View","type":"codeVoice"},{"type":"text","text":". This will show when the requested"},{"type":"text","text":" "},{"type":"text","text":"paywall is skipped. Defaults to "},{"code":"EmptyView()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"onErrorView"},{"content":[{"inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/superwall.com\/dashboard","isActive":true},{"type":"text","text":". If the paywall is set to "},{"type":"emphasis","inlineContent":[{"text":"Non Gated","type":"text"}]},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"type":"emphasis","inlineContent":[{"text":"Gated","type":"text"}]},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}],"type":"paragraph"}],"name":"feature"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This uses "},{"code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)","type":"codeVoice"},{"type":"text","text":" under the hood."}],"type":"paragraph"},{"type":"aside","name":"Warning","content":[{"inlineContent":[{"text":"You’re responsible for the deallocation of this view. If you have a ","type":"text"},{"code":"Paywall