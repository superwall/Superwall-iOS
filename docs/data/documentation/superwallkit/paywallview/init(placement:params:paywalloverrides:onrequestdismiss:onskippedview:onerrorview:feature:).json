ype":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}]},{"name":"onSkippedView","content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallSkippedReason","type":"reference"},{"text":" and returns an ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show","type":"text"},{"text":" ","type":"text"},{"text":"when the requested paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}]},{"name":"onErrorView","content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts an ","type":"text"},{"code":"Error","type":"codeVoice"},{"text":" and returns a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show when the requested","type":"text"},{"text":" ","type":"text"},{"text":"paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}]},{"name":"feature","content":[{"type":"paragraph","inlineContent":[{"text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/superwall.com\/dashboard","type":"reference"},{"text":". If the paywall is set to ","type":"text"},{"inlineContent":[{"type":"text","text":"Non Gated"}],"type":"emphasis"},{"text":", this will be called when","type":"text"},{"text":" ","type":"text"},{"text":"the paywall is dismissed or if the user is already paying. If the paywall is ","type":"text"},{"inlineContent":[{"type":"text","text":"Gated"}],"type":"emphasis"},{"text":", this will be called only if the user is already paying","type":"text"},{"text":" ","type":"text"},{"text":"or if they begin paying. If no payw