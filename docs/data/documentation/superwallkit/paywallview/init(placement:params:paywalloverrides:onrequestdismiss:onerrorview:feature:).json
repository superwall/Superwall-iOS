{"abstract":[{"text":"A SwiftUI paywall view that you can embed into your app.","type":"text"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/superwallkit\/paywallview\/init(placement:params:paywalloverrides:onrequestdismiss:onerrorview:feature:)"]}],"hierarchy":{"paths":[["doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit","doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"placement"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"params"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":" : "},{"kind":"keyword","text":"Any"},{"kind":"text","text":"]? = nil, "},{"kind":"externalParam","text":"paywallOverrides"},{"kind":"text","text":": "},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","preciseIdentifier":"c:@M@SuperwallKit@objc(cs)SWKPaywallOverrides","kind":"typeIdentifier","text":"PaywallOverrides"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"onRequestDismiss"},{"kind":"text","text":": (("},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallInfo","preciseIdentifier":"c:@M@SuperwallKit@objc(cs)SWKPaywallInfo","kind":"typeIdentifier","text":"PaywallInfo"},{"kind":"text","text":", "},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallResult","preciseIdentifier":"s:12SuperwallKit13PaywallResultO","kind":"typeIdentifier","text":"PaywallResult"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":")? = nil, "},{"kind":"externalParam","text":"onErrorView"},{"kind":"text","text":": "},{"kind":"attribute","text":"@escaping"},{"text":" (","kind":"text"},{"text":"Error","kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"OnErrorView","preciseIdentifier":"s:12SuperwallKit11PaywallViewVAAs5NeverORs_rlE07OnErrorD0xmfp"},{"kind":"text","text":", "},{"kind":"externalParam","text":"feature"},{"kind":"text","text":": (() -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":")? = nil)"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"placement","content":[{"inlineContent":[{"text":"The name of the placement, as you have defined on the Superwall dashboard.","type":"text"}],"type":"paragraph"}]},{"name":"params","content":[{"inlineContent":[{"type":"text","text":"Optional parameters you’d like to pass with your placement. These can be referenced within the rules"},{"type":"text","text":" "},{"type":"text","text":"of your campaign. Keys beginning with "},{"type":"codeVoice","code":"$"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}],"type":"paragraph"}]},{"name":"paywallOverrides","content":[{"inlineContent":[{"type":"text","text":"An optional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"onRequestDismiss","content":[{"type":"paragraph","inlineContent":[{"text":"An optional completion block that gets called when the paywall should dismiss. This defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block that accepts an "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" and returns a "},{"type":"codeVoice","code":"View"},{"type":"text","text":". This will show when the requested"},{"type":"text","text":" "},{"type":"text","text":"paywall is skipped. Defaults to "},{"type":"codeVoice","code":"EmptyView()"},{"type":"text","text":"."}]}],"name":"onErrorView"},{"content":[{"inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/superwall.com\/dashboard","isActive":true},{"type":"text","text":". If the paywall is set to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Non Gated"}]},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Gated"}]},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}],"type":"paragraph"}],"name":"feature"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"This uses ","type":"text"},{"code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)","type":"codeVoice"},{"text":" under the hood.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re responsible for the deallocation of this view. If you have a "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" presented somewhere"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" elsewhere, you will get a crash."}]}],"style":"warning","type":"aside","name":"Warning"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView\/init(placement:params:paywallOverrides:onRequestDismiss:onErrorView:feature:)"},"sections":[],"metadata":{"modules":[{"name":"SuperwallKit"}],"role":"symbol","title":"init(placement:params:paywallOverrides:onRequestDismiss:onErrorView:feature:)","platforms":[{"beta":false,"name":"iOS","introducedAt":"14.0","deprecated":false,"unavailable":false},{"beta":false,"name":"iPadOS","introducedAt":"14.0","deprecated":false,"unavailable":false},{"beta":false,"name":"Mac Catalyst","introducedAt":"14.0","deprecated":false,"unavailable":false}],"externalID":"s:12SuperwallKit11PaywallViewVAAs5NeverORs_rlE9placement6params16paywallOverrides16onRequestDismiss0j5ErrorD07featureACyxAEGSS_SDySSypGSgAA0cI0CSgyAA0C4InfoC_AA0C6ResultOtcSgxs0M0_pcyycSgtcfc","roleHeading":"Initializer","symbolKind":"init","conformance":{"constraints":[{"code":"OnErrorView","type":"codeVoice"},{"type":"text","text":" conforms to "},{"code":"View","type":"codeVo