{"text":"be dropped.","type":"text"}]}],"name":"params"},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional ","type":"text"},{"isActive":true,"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides","type":"reference"},{"text":" object whose parameters override the paywall defaults. Use this","type":"text"},{"text":" ","type":"text"},{"text":"to override products and whether it ignores the subscription status. Defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"paywallOverrides"},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional completion block that gets called when the paywall should dismiss. This defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and the SDK","type":"text"},{"text":" ","type":"text"},{"text":"will call ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}],"name":"onRequestDismiss"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts an ","type":"text"},{"code":"Error","type":"codeVoice"},{"text":" and returns a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show when the requested","type":"text"},{"text":" ","type":"text"},{"text":"paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"onErrorView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/superwall.com\/dashboard","type":"reference"},{"text":". If the paywall is set to ","type":"text"},{"inlineContent":[{"type":"text","text":"Non Gated"}],"type":"emphasis"},{"text":", this will be called when","type":"text"},{"text":" ","type":"text"},{"text":"the paywall is dismissed or if the user is already paying. If the paywall is ","type":"text"},{"inlineContent":[{"text":"Gated","type":"text"}],"type":"emphasis"},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}],"name":"feature"}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This uses "},{"identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)","isActive":true,"type":"reference"},{"type":"text","text":" under the hood."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"You’re responsible for the deallocation of this view. If you have a ","type":"text"},{"type":"codeVoice","code":"PaywallView"},{"text":" presented somewhere","type":"text"},{"text":" ","type":"text"},{"text":"and you try to present the same ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":" elsewhere, you will get a crash."}]}],"type":"aside","style":"warning","name":"Warning"}],"kind":"content"}],"identifier":{"url":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView\/init(placement:params:paywallOverrides:onRequestDismiss:onErrorView:feature:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit","doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallView"]]},"variants":[{"paths":["\/documentation\/superwallkit\/paywallview\/init(placement:params:paywalloverrides:onrequestdismiss:onerrorview:feature:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"A