all ","type":"text"},{"code":"presentationMode.wrappedValue.dismiss()","type":"codeVoice"},{"text":" by default. Otherwise you must perform the dismissal of the paywall.","type":"text"}]}]},{"name":"onErrorView","content":[{"type":"paragraph","inlineContent":[{"text":"A completion block that accepts an ","type":"text"},{"code":"Error","type":"codeVoice"},{"text":" and returns a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":". This will show when the requested","type":"text"},{"text":" ","type":"text"},{"text":"paywall is skipped. Defaults to ","type":"text"},{"code":"EmptyView()","type":"codeVoice"},{"text":".","type":"text"}]}]},{"name":"feature","content":[{"type":"paragraph","inlineContent":[{"text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/superwall.com\/dashboard","isActive":true,"type":"reference"},{"text":". If the paywall is set to ","type":"text"},{"inlineContent":[{"text":"Non Gated","type":"text"}],"type":"emphasis"},{"text":", this will be called when","type":"text"},{"text":" ","type":"text"},{"text":"the paywall is dismissed or if the user is already paying. If the paywall is ","type":"text"},{"inlineContent":[{"text":"Gated","type":"text"}],"type":"emphasis"},{"text":", this will be called only if the user is already paying","type":"text"},{"text":" ","type":"text"},{"text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error.","type":"text"}]}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This uses "},{"type":"codeVoice","code":"Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)"},{"type":"text","text":" under the hood."}],"type":"paragraph"},{"name":"Warning","style":"warning","type":"aside","con