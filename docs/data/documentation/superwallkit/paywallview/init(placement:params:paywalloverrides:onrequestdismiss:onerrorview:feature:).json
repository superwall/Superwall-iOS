t":"of your campaign. Keys beginning with "},{"type":"codeVoice","code":"$"},{"type":"text","text":" are reserved for Superwall and will be dropped. Values can be any"},{"type":"text","text":" "},{"type":"text","text":"JSON encodable value, URLs or Dates. Arrays and dictionaries as values are not supported at this time, and will"},{"type":"text","text":" "},{"type":"text","text":"be dropped."}]}]},{"name":"paywallOverrides","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional "},{"isActive":true,"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/PaywallOverrides"},{"type":"text","text":" object whose parameters override the paywall defaults. Use this"},{"type":"text","text":" "},{"type":"text","text":"to override products and whether it ignores the subscription status. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"name":"onRequestDismiss","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional completion block that gets called when the paywall should dismiss. This defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and the SDK"},{"type":"text","text":" "},{"type":"text","text":"will call "},{"type":"codeVoice","code":"presentationMode.wrappedValue.dismiss()"},{"type":"text","text":" by default. Otherwise you must perform the dismissal of the paywall."}]}]},{"name":"onErrorView","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block that accepts an "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" and returns a "},{"type":"codeVoice","code":"View"},{"type":"text","text":". This will show when the requested"},{"type":"text","text":" "},{"type":"text","text":"paywall is skipped. Defaults to "},{"type":"codeVoice","code":"EmptyView()"},{"type":"text","text":"."}]}]},{"name":"feature","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A completion block containing a feature that you wish to paywall. Access to this block is remotely configurable via the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/superwall.com\/dashboard"},{"type":"text","text":". If the paywall is set to "},{"inlineContent":[{"text":"Non Gated","type":"text"}],"type":"emphasis"},{"type":"text","text":", this will be called when"},{"type":"text","text":" "},{"type":"text","text":"the paywall is dismissed or if the user is already paying. If the paywall is "},{"inlineContent":[{"text":"Gated","type":"text"}],"type":"emphasis"},{"type":"text","text":", this will be called only if the user is already paying"},{"type":"text","text":" "},{"type":"text","text":"or if they begin paying. If no paywall is configured, this gets called immediately. This will not be called in the event of an error."}]}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses "},{"isActive":true,"type":"reference","identifier":"doc:\/\/superwall-ios.SuperwallKit\/documentation\/SuperwallKit\/Superwall\/getPaywall(forPlacement:params:paywallOverrides:delegate:)"},{"type":"text","text":" under the hood."}]},{"type":"aside","name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re responsible for the deallocation of this view. If you have a "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" presented somewhere"},{"type":"text","text":" "},{"type":"text","text":"and you try to present the same "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" elsewhere, you will get a crash."}]}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/superwallkit\/paywallview\/init(placement:params:paywalloverrides:onrequestdismiss:onerrorview:feature:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"A